PORT=3030

SOCKETPATH="/var/run/docker.sock"
BACKEND_WALLET_SEED="test test test test test test test test test test test junk"
JWT_SECRET=... optional

CONFIG_APP_URL=...
CONFIG_INDEXER_URL=...
CONFIG_CHAIN=... (default polygon)

ALCHEMY_RPC_KEY=...
COINGECKO_API_KEY=...
TELEGRAM_BOT_TOKEN=...

STORJ_ACCESSKEY=...
STORJ_SECRETACCESSKEY=...
STORJ_BUCKET=...
STORJ_REGION=EU1
STORJ_ENDPOINT=https://gateway.storjshare.io

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/wrytlabs?schema=public"
DATABASE_FALLBACK_URL="postgresql://user:password@backup-host:5432/wrytlabs?schema=public"

# Docker Database Configuration
DOCKER_DB_NAME=wrytlabs-postgres-dev
DOCKER_DB_IMAGE=postgres:15-alpine
DOCKER_DB_PORT=5433
DOCKER_DB_DATABASE=wrytlabs_dev
DOCKER_DB_USER=wrytlabs
DOCKER_DB_PASSWORD=dev_password
