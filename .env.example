# Application
NODE_ENV=development
PORT=3030
API_KEY_SECRET=your-super-secret-key-at-least-32-chars-long
BASE_URL=http://localhost:3030

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wrytes

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis

# AI (optional)
ANTHROPIC_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_DOMAIN=
TELEGRAM_WEBHOOK_PATH=/telegram/webhook

# Etherscan
ETHERSCAN_API_KEY=

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
