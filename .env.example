# Application
NODE_ENV=development
PORT=3030
API_KEY_SECRET=your-super-secret-key-at-least-32-chars-long
ENCRYPTION_KEY=your-super-secret-key-at-least-32-chars-long
BASE_URL=http://localhost:3030

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wrytes

# Redis (used for caching and BullMQ job queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis

# AI (optional)
ANTHROPIC_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_DOMAIN=
TELEGRAM_WEBHOOK_PATH=/telegram/webhook

# Alchemy
ALCHEMY_API_KEY=
# Required when MONITOR_MODE=webhook — shared secret from Alchemy dashboard
ALCHEMY_WEBHOOK_SECRET=

# 1inch API
ONEINCH_API_KEY=

# Wallet Configuration
WALLET_PRIVATE_KEY=

# Kraken — Wrytes AG operator account
KRAKEN_PUBLIC_KEY=
KRAKEN_PRIVATE_KEY=
KRAKEN_ADDRESS_KEY=
# Withdrawal key names for Wrytes AG's registered bank accounts on Kraken
KRAKEN_CHF_WITHDRAW_KEY=
KRAKEN_EUR_WITHDRAW_KEY=

# Deribit API Configuration
DERIBIT_CLIENT_ID=
DERIBIT_CLIENT_SECRET=
DERIBIT_BASE_URL=

# Off-ramp monitor
# MONITOR_MODE: "polling" (dev) or "webhook" (prod)
MONITOR_MODE=polling
MONITOR_POLL_INTERVAL_MS=60000

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
