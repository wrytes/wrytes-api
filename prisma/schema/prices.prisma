model TokenMinAmount {
  symbol    String   @id
  minAmount Decimal  @default(0) @db.Decimal(36, 18)
  updatedAt DateTime @updatedAt
}

/// Raw exchange rates fetched from each source. Stored for audit and cold-start restore.
model PriceRate {
  from      String
  to        String
  source    String
  value     Float
  fetchedAt DateTime

  @@id([from, to, source])
  @@index([from])
}

/// Resolved per-symbol prices (latest). Written after each refresh cycle.
model PriceCache {
  symbol    String   @id
  usdPrice  Float?
  chfPrice  Float?
  eurPrice  Float?
  updatedAt DateTime @updatedAt
}

model AlchemyCache {
  id          String   @id @default(cuid())
  requestType String
  parameters  String
  response    Json
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@unique([requestType, parameters])
  @@index([expiresAt])
}
