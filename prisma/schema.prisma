generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Users
// ---------------------------------------------------------------------------

model User {
  id                   String  @id @default(cuid())
  telegramId           BigInt  @unique
  telegramHandle       String?
  notificationsEnabled Boolean @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  apiKeys      ApiKey[]
  magicLinks   MagicLink[]
  scopes       UserScope[]
  safeWallets  SafeWallet[]
}

// ---------------------------------------------------------------------------
// Scopes / Permissions
// ---------------------------------------------------------------------------

/// Available scope keys: USER, ADMIN, AI, ALCHEMY, ...
/// No entry for a user = no permission (default false).
model Scope {
  key         String  @id   // e.g. USER, ADMIN, AI, ALCHEMY
  description String?

  users UserScope[]
}

model UserScope {
  userId   String
  scopeKey String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  scope Scope @relation(fields: [scopeKey], references: [key], onDelete: Cascade)

  @@id([userId, scopeKey])
}

// ---------------------------------------------------------------------------
// Auth / API Keys
// ---------------------------------------------------------------------------

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  keyId      String    @unique
  secretHash String
  expiresAt  DateTime?
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MagicLink {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Safe deposit wallets
// ---------------------------------------------------------------------------

model SafeWallet {
  id         String    @id @default(cuid())
  userId     String
  address    String    @unique
  chainId    Int
  label      String    @default("primary")
  saltNonce  String
  deployed   Boolean   @default(false)
  deployedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chainId, label])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Alchemy cache
// ---------------------------------------------------------------------------

model AlchemyCache {
  id          String   @id @default(cuid())
  requestType String
  parameters  String
  response    Json
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@unique([requestType, parameters])
  @@index([expiresAt])
}
