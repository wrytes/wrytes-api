generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Users
// ---------------------------------------------------------------------------

model User {
  id                   String  @id @default(cuid())
  telegramId           BigInt  @unique
  telegramHandle       String?
  notificationsEnabled Boolean @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  apiKeys      ApiKey[]
  magicLinks   MagicLink[]
  scopes       UserScope[]
  safeWallets  SafeWallet[]
  profile      UserProfile?
  bankAccounts BankAccount[]
  offRampRoutes OffRampRoute[]
}

// ---------------------------------------------------------------------------
// User profile (KYC / KYB)
// ---------------------------------------------------------------------------

model UserProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  firstName    String
  lastName     String
  businessName String?
  dateOfBirth  DateTime?
  street       String?
  city         String?
  postalCode   String?
  country      String?   // ISO 3166-1 alpha-2, e.g. "CH"
  isVerified   Boolean   @default(false)
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Scopes / Permissions
// ---------------------------------------------------------------------------

/// Available scope keys: USER, ADMIN, AI, ALCHEMY, KRAKEN, DERIBIT, SAFE, OFFRAMP
/// No entry for a user = no permission (default false).
model Scope {
  key         String  @id   // e.g. USER, ADMIN, AI, ALCHEMY
  description String?

  users UserScope[]
}

model UserScope {
  userId   String
  scopeKey String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  scope Scope @relation(fields: [scopeKey], references: [key], onDelete: Cascade)

  @@id([userId, scopeKey])
}

// ---------------------------------------------------------------------------
// Auth / API Keys
// ---------------------------------------------------------------------------

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  keyId      String    @unique
  secretHash String
  expiresAt  DateTime?
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MagicLink {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Safe deposit wallets
// ---------------------------------------------------------------------------

model SafeWallet {
  id         String    @id @default(cuid())
  userId     String
  address    String    @unique
  chainId    Int
  label      String    @default("primary")
  saltNonce  String
  deployed   Boolean   @default(false)
  deployedAt DateTime?
  createdAt  DateTime  @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  offRampRoute OffRampRoute?

  @@unique([userId, chainId, label])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Bank accounts
// ---------------------------------------------------------------------------

enum FiatCurrency {
  CHF
  EUR
  // USD
}

model BankAccount {
  id           String      @id @default(cuid())
  userId       String
  iban         String      // AES-256-GCM encrypted
  bic          String
  holderName   String
  currency     FiatCurrency
  label        String      @default("default")
  isDefault    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  offRampRoutes OffRampRoute[]

  @@unique([userId, label])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Off-ramp routes
// ---------------------------------------------------------------------------

enum OffRampRouteStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

model OffRampRoute {
  id               String             @id @default(cuid())
  userId           String
  label            String
  safeWalletId     String             @unique
  targetCurrency   FiatCurrency
  bankAccountId    String
  minTriggerAmount Decimal            @default(0) @db.Decimal(36, 18)
  status           OffRampRouteStatus @default(ACTIVE)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  safeWallet  SafeWallet  @relation(fields: [safeWalletId], references: [id])
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])
  executions  OffRampExecution[]

  @@unique([userId, label])
  @@index([userId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Off-ramp executions
// ---------------------------------------------------------------------------

enum OffRampExecutionStatus {
  DETECTED
  TRANSFERRING
  DEPOSITED
  SELLING
  SOLD
  WITHDRAWING
  COMPLETED
  FAILED
}

model OffRampExecution {
  id                 String                 @id @default(cuid())
  routeId            String
  userId             String
  status             OffRampExecutionStatus @default(DETECTED)
  tokenSymbol        String
  tokenAmount        Decimal                @db.Decimal(36, 18)
  onChainTxHash      String?
  krakenDepositRef   String?
  krakenOrderId      String?
  fiatAmount         Decimal?               @db.Decimal(18, 8)
  krakenWithdrawalId String?
  error              String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  route OffRampRoute @relation(fields: [routeId], references: [id])

  @@index([routeId])
  @@index([userId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Alchemy cache
// ---------------------------------------------------------------------------

model AlchemyCache {
  id          String   @id @default(cuid())
  requestType String
  parameters  String
  response    Json
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@unique([requestType, parameters])
  @@index([expiresAt])
}
