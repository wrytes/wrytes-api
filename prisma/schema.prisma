generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Users
// ---------------------------------------------------------------------------

model User {
  id                   String  @id @default(cuid())
  telegramId           BigInt  @unique
  telegramHandle       String?
  notificationsEnabled Boolean @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  apiKeys            ApiKey[]
  magicLinks         MagicLink[]
  scopes             UserScope[]
  safeWallets        SafeWallet[]
  profile            UserProfile?
  bankAccounts       BankAccount[]
  offRampRoutes      OffRampRoute[]
  userWallets        UserWallet[]
  walletAuthSessions WalletAuthSession[]
}

// ---------------------------------------------------------------------------
// User profile (KYC / KYB)
// ---------------------------------------------------------------------------

model UserProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  firstName    String
  lastName     String
  businessName String?
  dateOfBirth  DateTime?
  street       String?
  city         String?
  postalCode   String?
  country      String?   // ISO 3166-1 alpha-2, e.g. "CH"
  isVerified   Boolean   @default(false)
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Scopes / Permissions
// ---------------------------------------------------------------------------

/// Available scope keys: USER, ADMIN, AI, ALCHEMY, KRAKEN, DERIBIT, SAFE, OFFRAMP
/// No entry for a user = no permission (default false).
model Scope {
  key         String  @id   // e.g. USER, ADMIN, AI, ALCHEMY
  description String?

  users UserScope[]
}

model UserScope {
  userId   String
  scopeKey String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  scope Scope @relation(fields: [scopeKey], references: [key], onDelete: Cascade)

  @@id([userId, scopeKey])
}

// ---------------------------------------------------------------------------
// Auth / API Keys
// ---------------------------------------------------------------------------

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  keyId      String    @unique
  secretHash String
  label      String?
  expiresAt  DateTime?
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MagicLink {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Safe deposit wallets
// ---------------------------------------------------------------------------

model SafeWallet {
  id         String    @id @default(cuid())
  userId     String
  address    String    @unique
  chainId    Int
  label      String    @default("primary")
  saltNonce  String
  deployed   Boolean   @default(false)
  deployedAt DateTime?
  createdAt  DateTime  @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  offRampRoute OffRampRoute?

  @@unique([userId, chainId, label])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Bank accounts
// ---------------------------------------------------------------------------

enum FiatCurrency {
  CHF
  EUR
  // USD
}

model BankAccount {
  id           String      @id @default(cuid())
  userId       String
  iban         String      // AES-256-GCM encrypted
  bic          String
  currency     FiatCurrency
  label        String      @default("default")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  offRampRoutes OffRampRoute[]

  @@unique([userId, label])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Off-ramp routes
// ---------------------------------------------------------------------------

enum OffRampRouteStatus {
  ACTIVE
  PAUSED
}

model OffRampRoute {
  id               String             @id @default(cuid())
  userId           String
  label            String
  safeWalletId     String             @unique
  targetCurrency   FiatCurrency
  bankAccountId    String
  status           OffRampRouteStatus @default(ACTIVE)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  safeWallet  SafeWallet  @relation(fields: [safeWalletId], references: [id])
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])
  executions  OffRampExecution[]

  @@unique([userId, label])
  @@index([userId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Off-ramp executions
// ---------------------------------------------------------------------------

enum OffRampExecutionStatus {
  DETECTED
  CONVERTING
  TRANSFERRING
  DEPOSITED
  SELLING
  SOLD
  WITHDRAWING
  PENDING_BANK_TRANSFER
  SETTLED
  FAILED
}

model OffRampExecution {
  id                 String                 @id @default(cuid())
  routeId            String
  userId             String
  status             OffRampExecutionStatus @default(DETECTED)
  tokenSymbol        String
  tokenAmount        Decimal                @db.Decimal(36, 18)
  depositTxHash      String?                @unique
  conversionTxHash   String?
  krakenTokenSymbol  String?
  krakenTokenAmount  Decimal?               @db.Decimal(36, 18)
  onChainTxHash      String?
  krakenDepositRef   String?
  krakenOrderId      String?
  fiatAmount         Decimal?               @db.Decimal(18, 8)
  krakenWithdrawalId String?
  bankTransferRef    String?
  error              String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  route OffRampRoute @relation(fields: [routeId], references: [id])

  @@index([routeId])
  @@index([userId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// User wallets — EOA addresses linked to a user account
// ---------------------------------------------------------------------------

/// Linked external wallet (EOA). One address can belong to exactly one user.
model UserWallet {
  id        String   @id @default(cuid())
  userId    String
  address   String   @unique // EIP-55 checksummed; globally unique
  label     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_wallets")
}

/// Reverse magic-key: generated in the app, submitted via Telegram /link to bind a wallet.
model WalletLinkToken {
  id            String    @id @default(cuid())
  token         String    @unique
  walletAddress String    // the address being linked
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([walletAddress])
  @@map("wallet_link_tokens")
}

/// Short-lived sign-in challenge/nonce for EIP-191 wallet authentication.
model WalletAuthChallenge {
  id        String   @id @default(cuid())
  address   String
  nonce     String   @unique
  message   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([address])
  @@map("wallet_auth_challenges")
}

/// Wallet sign-in session — stays PENDING until the user approves via Telegram.
model WalletAuthSession {
  id             String           @id @default(cuid())
  sessionId      String           @unique @default(cuid())
  walletAddress  String
  userId         String
  status         WalletAuthStatus @default(PENDING)
  jwt            String?          // set on APPROVED
  telegramChatId BigInt           // user's TG chat for the 2FA prompt
  telegramMsgId  Int?             // stored so we can edit the message after decision
  expiresAt      DateTime
  createdAt      DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("wallet_auth_sessions")
}

enum WalletAuthStatus {
  PENDING
  APPROVED
  DENIED
  EXPIRED
}

// ---------------------------------------------------------------------------
// Token minimum amounts (global, admin-editable)
// ---------------------------------------------------------------------------

model TokenMinAmount {
  symbol    String   @id
  minAmount Decimal  @default(0) @db.Decimal(36, 18)
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Price rates and cache
// ---------------------------------------------------------------------------

/** Raw exchange rates fetched from each source. Stored for audit and cold-start restore. */
model PriceRate {
  from      String
  to        String
  source    String
  value     Float
  fetchedAt DateTime

  @@id([from, to, source])
  @@index([from])
}

/** Resolved per-symbol prices (latest). Written after each refresh cycle. */
model PriceCache {
  symbol    String   @id
  usdPrice  Float?
  chfPrice  Float?
  eurPrice  Float?
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Alchemy cache
// ---------------------------------------------------------------------------

model AlchemyCache {
  id          String   @id @default(cuid())
  requestType String
  parameters  String
  response    Json
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@unique([requestType, parameters])
  @@index([expiresAt])
}
